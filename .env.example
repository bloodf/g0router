# g0router configuration
# Copy to .env for local development, or export these variables in production.

# Server
PORT=20128
BIND_ADDRESS=127.0.0.1
DATA_DIR=~/.g0router

# Security
# API_KEY_SECRET is required when REQUIRE_API_KEY=true.
# Generate with: openssl rand -hex 32
# JWT_SECRET is reserved for compatibility and is not used by the current auth path.
JWT_SECRET=
API_KEY_SECRET=

# Access control
REQUIRE_API_KEY=true

# Logging
ENABLE_REQUEST_LOGS=false

# RTK (Response Token Kompression)
RTK_ENABLED=true

# Caveman mode
CAVEMAN_ENABLED=false
CAVEMAN_LEVEL=full   # lite | full | ultra

# Network
# HTTPS_PROXY=http://proxy:8080

# Vertex AI (optional)
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=us-central1

# Optional live provider smoke tests. Skipped unless G0ROUTER_LIVE_TESTS=1.
# G0ROUTER_LIVE_TESTS=0
# G0ROUTER_E2E_MINIMAX_API_KEY=
# G0ROUTER_E2E_MINIMAX_BASE_URL=
